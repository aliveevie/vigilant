# Vigilant Sentinel Agent — config
# The agent needs its own funded key to pay warning deposits (~0.26 STT each).
# Use a dedicated hot wallet, NOT your deployer/governor key.
SENTINEL_PRIVATE_KEY=0x...

# Somnia Shannon testnet
RPC_URL=https://api.infra.testnet.somnia.network/

# Polling cadence (ms) for the monitor loop
POLL_INTERVAL_MS=12000

# A native-balance drop larger than this fraction (0-1) of a covered contract's
# tracked balance, within one poll window, is treated as an exploit signal.
DROP_THRESHOLD=0.30

# Optional: comma-separated extra contracts to watch even if not covered yet.
EXTRA_WATCHLIST=
